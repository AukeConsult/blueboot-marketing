{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json",
    "predeploy": ["py firestore_sync.py --no-discover"]
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  },
  "functions": [
    {
      "codebase": "crm",
      "source": "functions-crm",
      "runtime": "python312",
      "ignore": ["venv", ".venv", "**/__pycache__/**"]
    },
    {
      "codebase": "auth",
      "source": "functions-auth",
      "runtime": "nodejs22",
      "ignore": ["node_modules"]
    },
    {
      "codebase": "smartmail",
      "source": "functions-smartmail",
      "runtime": "python313",
      "ignore": ["venv", ".venv", "**/__pycache__/**"]
    }
  ]
}
