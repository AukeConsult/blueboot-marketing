# ============================================================================
# .env.update  --  formerly-hardcoded constants, now overridable via env.
# Append these to your secret .env (and to the Cloud Functions env for
# functions-crm). Every value below is the CURRENT default, so appending this
# as-is changes nothing; edit a value to override it.
# ============================================================================

# -- CRM infra (functions-crm/main.py) ---------------------------------------
GCP_PROJECT=blueboot-market
GCP_LOCATION=us-central1
TASKS_QUEUE=crm-queue
WORKER_BASE_URL=https://us-central1-blueboot-market.cloudfunctions.net/crmWorker/api/crm/worker

# -- Firestore collection / doc names ----------------------------------------
JOBS_COLLECTION=crm_jobs
FILTER_FACETS_COLLECTION=filter_facets
GDISK_SETTINGS_COLLECTION=settings
GDISK_SETTINGS_DOC=gdisk

# -- Google Sheets (functions-crm/crm/sheets_config.py) ----------------------
CONTACT_SHEET_ID=1aMglV53NiMEArjld37HN5cxliyNRGzIP2mrM4kwlupA
TEMPLATE_SHEET_ID=1b1kGKIldeawESH3RYiYjOqRFXRR5kG_81qYRFZI1gSY
CONTACT_TAB=contacts
TEMPLATE_TAB=Outreach
CRM_COLLECTION=crm
CRM_CONTACT_DOC=contact_select
CRM_TEMPLATE_DOC=crm_template

# -- Filter-facets tuning (app/build_filter_facets.py, filter_count_lib.py) --
FACET_TOP_N_LOCATION=200
FACET_TOP_N_KEYWORDS=100
FACET_TOP_N_AI_PLATFORM=10
FACET_TITLE_MIN_COUNT=20

# -- gdisk (Google Drive folder) ---------------------------------------------
# Set this to the Drive folder ID the gdisk interface should use (see
# docs/gdisk_interface.md). Empty = not configured.
GDISK_FOLDER_ID=1

# -- gdisk service account ---------------------------------------------------
# The identity the Cloud Functions backend runs as. Gen 2 functions / Cloud Run
# use the default COMPUTE service account: <project-number>-compute@developer.gserviceaccount.com
# Share the Drive folder with THIS account (Editor). Shown in the Check access card.
GDISK_SERVICE_ACCOUNT=77823673522-compute@developer.gserviceaccount.com
