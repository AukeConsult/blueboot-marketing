# ============================================================================
# SMART-MAIL ADDITIONS — proposed new vars for the campaign send/reply system
# Merge the relevant blocks into your real .env (keep secrets out of git).
# Per-account secrets (passwords) belong in app/mail_setup_secrets.py, which
# is gitignored via the "*secrets.py" pattern in .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# Multi-account mail config
# The smart-mail-not-in-use sender/reader resolve named accounts through
# app/mail_setup_secrets.py (MAIL_ACCOUNTS dict + get_account(alias)).
# Define one block per account here; mirror the values into that file.
# ----------------------------------------------------------------------------

# Account used when a campaign doesn't set "outreach_email_account"
DEFAULT_MAIL_ACCOUNT=sales

# --- Account "sales" -> sales@blueboot.ai (cPanel / webmail) ---------------
SALES_SMTP_HOST=mail.blueboot.ai        # confirm exact host in cPanel > Email Accounts > Connect Devices
SALES_SMTP_PORT=465                     # 465 = implicit SSL (SMTP_SSL) | 587 = STARTTLS (SMTP + starttls())
SALES_SMTP_USER=sales@blueboot.ai
SALES_SMTP_PASSWORD=
SALES_FROM_NAME=BlueBoot Sales
SALES_FROM_ADDR=sales@blueboot.ai
SALES_IMAP_HOST=mail.blueboot.ai
SALES_IMAP_PORT=993

# --- Account "leif" -> leif@blueboot.no (Gmail) -----------------------------
LEIF_SMTP_HOST=smtp.gmail.com
LEIF_SMTP_PORT=587
LEIF_SMTP_USER=leif@blueboot.no
LEIF_SMTP_PASSWORD=                     # Gmail App Password (not the account login password)
LEIF_FROM_NAME=Leif Auke
LEIF_FROM_ADDR=leif@blueboot.no
LEIF_IMAP_HOST=imap.gmail.com
LEIF_IMAP_PORT=993

# (legacy single-account vars — already in .env / used by send_mail.py & test_send_email.py.
#  Keep them so those scripts keep working; smart-mail-not-in-use uses the per-account vars above.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=leif@blueboot.no
# SMTP_PASSWORD=
# MAIL_FROM=Leif Auke <leif@blueboot.no>
# MAIL_REPLY_TO=

# ----------------------------------------------------------------------------
# Smart-mail campaign sender / worker
# ----------------------------------------------------------------------------
CAMPAIGN_SEND_DELAY_SECONDS=12          # pause between sends — deliverability throttle (already read by sender)
CAMPAIGN_WORKER_POLL_SECONDS=15         # how often the worker checks for "queued" campaigns (already read by worker)
MAX_SENDS_PER_HOUR=50                   # per-account hourly cap; sender should pause/requeue beyond this
MAX_SENDS_PER_DAY=300                   # per-account daily cap
BOUNCE_RATE_PAUSE_THRESHOLD=0.05        # auto-pause a campaign if failed/bounced ratio exceeds 5%

# One-click unsubscribe — strongly recommended for inbox placement
UNSUBSCRIBE_BASE_URL=                   # e.g. https://blueboot-market.web.app/unsubscribe?c={contact_id}
UNSUBSCRIBE_MAILTO=                     # e.g. unsubscribe@blueboot.ai  (used in List-Unsubscribe header)

# ----------------------------------------------------------------------------
# Smart-mail reply reader (IMAP polling worker — new)
# ----------------------------------------------------------------------------
REPLY_POLL_SECONDS=120                  # how often to check inboxes for new messages
REPLY_LOOKBACK_DAYS=3                   # how far back to scan on first run / after downtime
REPLY_ACCOUNTS=sales,leif               # comma-separated account aliases to poll for replies

# ----------------------------------------------------------------------------
# Stats / AI reply classification (phase 2 — optional)
# ----------------------------------------------------------------------------
REPLY_CLASSIFY_WITH_AI=false            # set true to auto-tag replies via OpenAI
                                        # (interested / not interested / out-of-office / unsubscribe)
