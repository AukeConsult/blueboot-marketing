# functions-smartmail/.env.blueboot-market
#
# Non-secret config for the deployed smart-mail Cloud Function.
# Loaded natively by the Cloud Functions (2nd gen) runtime at deploy time --
# do NOT put SALES_SMTP_PASSWORD here; it is a Secret Manager secret
# (see deploy instructions: `firebase functions:secrets:set SALES_SMTP_PASSWORD`).
#
# >>> FILL IN THE REAL VALUES BELOW (same names/values as your local app/.env;
#     copy them yourself -- this agent does not read .env/secret files). <<<

GCP_LOCATION=us-central1

DEFAULT_MAIL_ACCOUNT=sales

# --- sales@blueboot.ai (cPanel / webmail) ---------------------------------
SALES_SMTP_HOST=cpweb02.misshosting.no
SALES_SMTP_PORT=465
SALES_SMTP_USER=sales@blueboot.ai
SALES_FROM_NAME=Blueboot Sales
SALES_FROM_ADDR=sales@blueboot.ai
SALES_IMAP_HOST=cpweb02.misshosting.no
SALES_IMAP_PORT=993
# SALES_SMTP_PASSWORD -> Secret Manager secret, NOT here

# --- leif@blueboot.no (only fill in if this account is actually used) ----
# LEIF_SMTP_HOST=
# LEIF_SMTP_PORT=587
# LEIF_SMTP_USER=leif@blueboot.no
# LEIF_FROM_NAME=Leif
# LEIF_FROM_ADDR=leif@blueboot.no
# LEIF_IMAP_HOST=
# LEIF_IMAP_PORT=993
# LEIF_SMTP_PASSWORD -> Secret Manager secret, NOT here

# --- campaign sender tuning -----------------------------------------------
CAMPAIGN_SEND_DELAY_SECONDS=12
CAMPAIGN_WORKER_POLL_SECONDS=15
MAX_SENDS_PER_HOUR=50
MAX_SENDS_PER_DAY=300
BOUNCE_RATE_PAUSE_THRESHOLD=0.05

# --- one-click unsubscribe (List-Unsubscribe headers) ----------------------
UNSUBSCRIBE_BASE_URL=
UNSUBSCRIBE_MAILTO=

# --- reply matcher tuning ---------------------------------------------------
REPLY_POLL_SECONDS=120
REPLY_LOOKBACK_DAYS=7
REPLY_ACCOUNTS=sales
REPLY_CLASSIFY_WITH_AI=false
