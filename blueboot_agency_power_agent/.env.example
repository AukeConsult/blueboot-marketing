# Optional. Without these, the agent uses Bing HTML search fallback.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional OpenAI for stronger personalization. If empty, rule-based text is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

COUNTRY=Norway
MAX_RESULTS_PER_QUERY=25
MAX_PAGES_PER_SITE=8
REQUEST_DELAY_SECONDS=1.0
