# -- Firebase / Firestore -----------------------------------------------------
# Path to service account key file (used if FIREBASE_KEY_JSON is not set)
FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# Or inline the key as a JSON string (takes precedence over FIREBASE_CREDENTIALS)
FIREBASE_KEY_JSON=

# Firestore collection for leads (default: leads)
FIRESTORE_COLLECTION=leads

# -- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# -- Search APIs --------------------------------------------------------------
BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# GitHub token -- improves rate limits for GitHub org search (no scopes needed)
GITHUB_TOKEN=

# -- Crawler tuning -----------------------------------------------------------
MAX_RESULTS=200
MIN_SCORE=50
MAX_PAGES=6
MAX_COUNTRY=1000
GIVE_UP_AFTER=15
CRAWL_DELAY=1.0
CRAWL_WORKERS=20
LIMIT_PER_HOST=3

# -- Campaigns ----------------------------------------------------------------
CAMPAIGNS_DIR=
CAMPAIGN_LABEL=
QUERIES_FILE=

# -- Email / SMTP -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_REPLY_TO=
GMAIL_SENDER=

