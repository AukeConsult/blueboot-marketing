# ============================================================
# BlueBoot Agency Power Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Firebase Service Account ──────────────────────────────────────────────
# Paste the full content of your Firebase service account key as single-line JSON
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_KEY_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Alternative: path to a JSON key file (used if FIREBASE_KEY_JSON is not set)
# FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# Firestore collection for leads (default: leads)
FIRESTORE_COLLECTION=

# ── OpenAI ────────────────────────────────────────────────────────────────
# Required for all AI enrichment steps (site_enrich_agent, site_email_check, etc.)
OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-5.4-mini

# ── Brave Search API ──────────────────────────────────────────────────────
# Required for site_agent and lead_enrich_contacts
# Get it from: https://brave.com/search/api/
BRAVE_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────
# Optional — improves GitHub org search rate limits in lead_agent
# Create at: https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# ── Google Custom Search (optional) ──────────────────────────────────────
# Only needed if using Google CSE in lead_agent --mode search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── lead_agent tuning ─────────────────────────────────────────────────────
# These set default values for lead_agent CLI flags (can be overridden per-run)
MAX_RESULTS=200
MIN_SCORE=50
MAX_PAGES=6
MAX_COUNTRY=1000
GIVE_UP_AFTER=15
CRAWL_DELAY=1.0
CRAWL_WORKERS=20
LIMIT_PER_HOST=3

# ── SMTP / Outreach email sender ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=Your Name <your@email.com>
MAIL_REPLY_TO=
GMAIL_SENDER=

# ── Misc ──────────────────────────────────────────────────────────────────
# Custom query file override (leave empty to use countries.json)
QUERIES_FILE=
